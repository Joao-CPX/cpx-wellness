---
import Base from '../../layouts/Base.astro';
import { t, localeRoutes } from '../../i18n/utils';

const locale = 'en';
const i = t(locale);
const routes = localeRoutes[locale];
---

<Base title="Our Science" locale={locale} description="Understanding the science of cellular bioelectrics - the foundation of CellPowerX Wellness Center's frequency-based approach to well-being.">

  <!-- Hero -->
  <section class="page-hero section">
    <div class="container">
      <span class="label reveal">{i.ourScience.label}</span>
      <h1 class="reveal">{i.ourScience.heading}</h1>
      <p class="page-hero__body reveal">{i.ourScience.intro}</p>
    </div>
  </section>

  <!-- Tesla Quote -->
  <section class="section section--accent">
    <div class="container text-center">
      <blockquote class="quote reveal">
        <p class="quote__text">"{i.ourScience.teslaQuote}"</p>
        <footer class="quote__attribution">
          <img src="/images/Tesla.jpg" alt="Nikola Tesla" class="quote__avatar" />
          <strong>{i.ourScience.teslaAuthor}</strong>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Cells & Electricity -->
  <section class="section">
    <div class="container">
      <div class="science-row reveal">
        <div class="science-row__text">
          <h2>{i.ourScience.cellsHeading}</h2>
          <p>{i.ourScience.cellsBody}</p>
          <p>{i.ourScience.cellsBody2}</p>
        </div>
        <div class="science-row__img">
          <img src="/images/natural-cycles-of-electrical-variation.jpg" alt="Natural cycles of electrical variation" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Ions & Membrane Potential -->
  <section class="section section--accent">
    <div class="container">
      <div class="science-row science-row--reverse reveal">
        <div class="science-row__text">
          <h2>{i.ourScience.ionsHeading}</h2>
          <p>{i.ourScience.ionsBody}</p>
          <p>{i.ourScience.ionsBody2}</p>
        </div>
        <div class="science-row__img">
          <img src="/images/Cellular-bioelectrical-activity.jpg" alt="Cellular bioelectrical activity" loading="lazy" />
        </div>
      </div>
      <div class="science-disclaimer reveal" style="margin-top: var(--block-spacing);">
        <p>{i.ourScience.disclaimerNote}</p>
      </div>
    </div>
  </section>

  <!-- Membrane Potential as Reference -->
  <section class="section">
    <div class="container">
      <div class="science-block reveal">
        <h2>{i.ourScience.membraneHeading}</h2>
        <p>{i.ourScience.membraneBody}</p>
      </div>
    </div>
  </section>

  <!-- Role of Internal Environment -->
  <section class="section section--accent">
    <div class="container">
      <div class="science-block reveal">
        <h2>{i.ourScience.internalHeading}</h2>
        <p>{i.ourScience.internalBody}</p>
        <p>{i.ourScience.internalBody2}</p>
      </div>
    </div>
  </section>

  <!-- Cellular Bioelectrical Activity -->
  <section class="section">
    <div class="container">
      <div class="science-row reveal">
        <div class="science-row__text">
          <h2>{i.ourScience.activityHeading}</h2>
          <p>{i.ourScience.activityBody}</p>
          <p>{i.ourScience.activityBody2}</p>
        </div>
        <div class="science-row__img">
          <img src="/images/Cellular-bioelectrical-activity.jpg" alt="Cellular bioelectrical activity and membrane potential" loading="lazy" />
        </div>
      </div>
      <div class="science-highlight reveal" style="margin-top: var(--block-spacing);">
        <p>"{i.ourScience.keyStatement}"</p>
      </div>
      <p class="reveal" style="margin-top: 24px; font-size: 1.0625rem; line-height: 1.6;">{i.ourScience.keyStatementBody}</p>
    </div>
  </section>

  <!-- Natural Cellular Cycles -->
  <section class="section section--accent">
    <div class="container">
      <div class="science-row science-row--reverse reveal">
        <div class="science-row__text">
          <h2>{i.ourScience.cyclesHeading}</h2>
          <p>{i.ourScience.cyclesBody}</p>
          <p>{i.ourScience.cyclesBody2}</p>
          <p>{i.ourScience.cyclesBody3}</p>
        </div>
        <div class="science-row__img">
          <img src="/images/natural-cycles-of-electrical-variation.jpg" alt="Natural cycles of electrical variation" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- pH: Acid vs Alkaline -->
  <section class="section">
    <div class="container">
      <div class="science-row reveal">
        <div class="science-row__text">
          <h2>{i.ourScience.phHeading}</h2>
          <p>{i.ourScience.phBody}</p>
          <p>{i.ourScience.phBody2}</p>
          <p>{i.ourScience.phBody3}</p>
        </div>
        <div class="science-row__img">
          <img src="/images/Acid-Medium-vs.-Alkaline-Medium.jpg" alt="Acid Medium vs. Alkaline Medium" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-block cta-block--centered reveal">
        <h2>{i.ourScience.ctaHeading}</h2>
        <p style="margin-top: 16px; max-width: 620px;">{i.ourScience.ctaBody}</p>
        <a href={routes.contact} class="btn btn--cta" style="margin-top: 32px;">
          {i.ourScience.ctaCta}
          <i class="ph-light ph-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>

</Base>

<style>
  .page-hero {
    padding-top: calc(72px + var(--section-spacing));
    text-align: center;
  }

  .page-hero h1 {
    margin-bottom: 24px;
  }

  .page-hero__body {
    font-size: 1.0625rem;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  /* 2-column layout: 2/3 text + 1/3 image */
  .science-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--block-spacing);
    align-items: center;
  }

  @media (min-width: 768px) {
    .science-row {
      grid-template-columns: 2fr 1fr;
    }

    .science-row--reverse {
      grid-template-columns: 1fr 2fr;
    }

    .science-row--reverse .science-row__img {
      order: -1;
    }
  }

  .science-row__img {
    overflow: hidden;
    border-radius: var(--radius-block);
  }

  .science-row__img img {
    width: 100%;
    max-height: 400px;
    border-radius: var(--radius-block);
    object-fit: cover;
  }

  .science-row__text h2 {
    margin-bottom: 24px;
  }

  .science-row__text p {
    font-size: 1.0625rem;
    line-height: 1.6;
    max-width: none;
    margin-bottom: 16px;
  }

  .science-row__text p:last-child {
    margin-bottom: 0;
  }

  /* Quote */
  .quote {
    max-width: 720px;
    margin: 0 auto;
  }

  .quote__text {
    font-family: var(--font-body);
    font-weight: var(--fw-body);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.5;
    font-style: italic;
    max-width: none;
    margin-bottom: 24px;
  }

  .quote__attribution {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    font-size: 0.875rem;
  }

  .quote__attribution strong {
    opacity: 0.5;
  }

  .quote__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
  }

  /* Highlight block */
  .science-highlight {
    margin: 20px 0;
    padding: 20px 24px !important;
    background: rgba(0, 0, 0, 0.03);
    border-left: none;
    border-radius: var(--radius-input);
  }

  .science-highlight p {
    font-size: 0.9375rem;
    font-style: italic;
    margin-bottom: 0;
    opacity: 0.7;
  }

  /* Disclaimer */
  .science-disclaimer {
    max-width: none;
    padding: 32px;
    background: rgba(0, 0, 0, 0.03);
    border-radius: var(--radius-block);
  }

  .science-disclaimer h3 {
    margin-bottom: 12px;
    font-size: 0.875rem;
  }

  .science-disclaimer p {
    font-size: 0.875rem;
    line-height: 1.6;
    opacity: 0.6;
    max-width: none;
  }

  .science-block {
    max-width: 800px;
  }

  .science-block h2 {
    margin-bottom: 24px;
  }

  .science-block p {
    font-size: 1.0625rem;
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .science-block p:last-child {
    margin-bottom: 0;
  }

  .cta-block--centered {
    text-align: center;
  }

  .cta-block--centered p {
    margin-left: auto;
    margin-right: auto;
  }
</style>
