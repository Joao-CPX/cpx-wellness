---
import Base from '../../layouts/Base.astro';
import { t, localeRoutes } from '../../i18n/utils';

const locale = 'pt';
const i = t(locale);
const routes = localeRoutes[locale];
---

<Base title="Sobre" locale={locale} description="Fundado em 2005, o CellPowerX Wellness Center é o espaço pioneiro de Lisboa dedicado ao bem-estar bioeléctrico e baseado em frequências. Conheça o fundador Nuno Nina.">

  <section class="page-hero section">
    <div class="container">
      <span class="label reveal">{i.about.label}</span>
      <h1 class="reveal">{i.about.heading}</h1>
      <p class="page-hero__body reveal">{i.about.intro}</p>
    </div>
  </section>

  <section class="stats section--accent" style="padding: clamp(40px, 5vw, 64px) 0;">
    <div class="container">
      <div class="stats__grid" data-stagger>
        <div class="stats__item">
          <span class="stats__label">{i.about.stats.founded}</span>
          <span class="stats__value" data-counter="2005">2005</span>
        </div>
        <div class="stats__item">
          <span class="stats__label">{i.about.stats.journeys}</span>
          <span class="stats__value" data-counter="70000+">70.000+</span>
        </div>
        <div class="stats__item">
          <span class="stats__label">{i.about.stats.experience}</span>
          <span class="stats__value" data-counter="20+">20+</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="founder reveal">
        <div class="founder__image">
          <div class="img-frame">
            <div class="founder__placeholder">
              <i class="ph ph-user" style="font-size: 4rem; color: var(--cpx-accent);"></i>
            </div>
          </div>
        </div>
        <div class="founder__content">
          <h2>{i.about.founderName}</h2>
          <span class="label label--dark" style="margin-bottom: 20px; display: block;">{i.about.founderRole}</span>
          <p>{i.about.founderBio}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--accent">
    <div class="container">
      <div class="approach reveal">
        <h2>{i.about.approachHeading}</h2>
        <p class="approach__body">{i.about.approachBody}</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="ecosystem section-block section--accent reveal">
        <h2>{i.about.ecosystemHeading}</h2>
        <p style="margin-top: 16px; margin-bottom: 32px;">{i.about.ecosystemBody}</p>
        <a href="https://cellpowerx.com" target="_blank" rel="noopener" class="btn btn--secondary">
          {i.about.ecosystemCta}
          <i class="ph ph-arrow-up-right"></i>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="cta-block reveal">
        <h2>{i.firstAppointment.heading}</h2>
        <p style="margin-top: 16px; color: rgba(250, 248, 245, 0.8);">{i.firstAppointment.body}</p>
        <a href={routes.contact} class="btn btn--primary" style="margin-top: 32px;">
          {i.firstAppointment.cta}
          <i class="ph ph-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>

</Base>

<style>
  .page-hero {
    padding-top: calc(72px + var(--section-spacing));
    background: linear-gradient(160deg, var(--wc-warm-white), var(--wc-mist));
  }
  .page-hero h1 { margin-top: 12px; margin-bottom: 24px; }
  .page-hero__body { font-size: 1.0625rem; max-width: 640px; }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--grid-gap);
    text-align: center;
  }
  @media (max-width: 480px) {
    .stats__grid { grid-template-columns: 1fr; gap: 24px; }
  }
  .stats__label {
    display: block;
    font-family: var(--font-heading);
    font-weight: var(--fw-heading);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.6875rem;
    color: var(--wc-charcoal);
    opacity: 0.6;
    margin-bottom: 8px;
  }
  .stats__value {
    font-family: var(--font-heading);
    font-weight: var(--fw-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: 0.02em;
    color: var(--wc-charcoal);
  }

  .founder {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--block-spacing);
    align-items: start;
  }
  @media (min-width: 768px) {
    .founder { grid-template-columns: 2fr 3fr; }
  }
  .founder__image .img-frame {
    aspect-ratio: 3/4;
    background: linear-gradient(135deg, rgba(195, 214, 221, 0.3), rgba(232, 224, 212, 0.3));
  }
  .founder__placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
  }
  .founder__content h2 { margin-bottom: 4px; }
  .founder__content p { font-size: 0.9375rem; line-height: 1.8; }

  .approach { max-width: 720px; }
  .approach__body { margin-top: 20px; font-size: 1.0625rem; max-width: none; }
  .ecosystem { max-width: 800px; }
  .cta-block { max-width: 640px; }
</style>
