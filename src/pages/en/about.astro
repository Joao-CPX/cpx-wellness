---
import Base from '../../layouts/Base.astro';
import { t, localeRoutes } from '../../i18n/utils';

const locale = 'en';
const i = t(locale);
const routes = localeRoutes[locale];
---

<Base title="About" locale={locale} description="Founded in 2009, CellPowerX Wellness Center is Lisbon's pioneering space for bioelectrical and frequency-based well-being. Meet founder Nuno Nina.">

  <!-- Intro -->
  <section class="page-hero section">
    <div class="container">
      <span class="label reveal">{i.about.label}</span>
      <h1 class="reveal">{i.about.heading}</h1>
      <p class="page-hero__body reveal">{i.about.intro}</p>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="stats section--accent" style="padding: clamp(40px, 5vw, 64px) 0;">
    <div class="container">
      <div class="stats__grid" data-stagger>
        <div class="stats__item">
          <span class="stats__label">{i.about.stats.founded}</span>
          <span class="stats__value">2009</span>
        </div>
        <div class="stats__item">
          <span class="stats__label">{i.about.stats.journeys}</span>
          <span class="stats__value" data-counter="70000+">70,000+</span>
        </div>
        <div class="stats__item">
          <span class="stats__label">{i.about.stats.experience}</span>
          <span class="stats__value" data-counter="20+">20+</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Founder Profile -->
  <section class="section">
    <div class="container">
      <div class="founder reveal">
        <div class="founder__image">
          <img src="/images/nuno-nina.webp" alt="Nuno Nina — Founder of CellPowerX" class="founder__photo" loading="lazy" />
        </div>
        <div class="founder__content">
          <h2>{i.about.founderName}</h2>
          <span class="label label--dark" style="margin-bottom: 20px; display: block;">{i.about.founderRole}</span>
          <p>{i.about.founderBio}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Approach -->
  <section class="section section--accent">
    <div class="container">
      <div class="approach reveal">
        <h2>{i.about.approachHeading}</h2>
        <p class="approach__body">{i.about.approachBody}</p>
      </div>
    </div>
  </section>

  <!-- CellPowerX Connection -->
  <section class="cpx-banner reveal">
    <img src="https://www.cellpowerx.com/cdn/shop/files/Partnership_banner_2800x1000_3c9de5a7-dc26-4f6a-96dc-711ac72229a3.webp?v=1767978956&width=2800" alt="CellPowerX Ecosystem" class="cpx-banner__img" loading="lazy" />
    <div class="cpx-banner__overlay"></div>
    <div class="cpx-banner__content">
      <h2>{i.about.ecosystemHeading}</h2>
      <p>{i.about.ecosystemBody}</p>
      <a href="https://www.cellpowerx.com" target="_blank" rel="noopener" class="btn btn--cta">
        {i.about.ecosystemCta}
        <i class="ph-light ph-arrow-up-right"></i>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-block cta-block--centered reveal">
        <h2>{i.firstAppointment.heading}</h2>
        <p style="margin-top: 16px;">{i.firstAppointment.body}</p>
        <a href={routes.contact} class="btn btn--primary" style="margin-top: 32px;">
          {i.firstAppointment.cta}
          <i class="ph-light ph-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>

</Base>

<style>
  .page-hero {
    padding-top: calc(72px + var(--section-spacing));
  }

  .page-hero h1 {
    margin-top: 12px;
    margin-bottom: 24px;
  }

  .page-hero__body {
    font-size: 1.0625rem;
    max-width: 640px;
  }

  /* Stats */
  .stats__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--grid-gap);
    text-align: center;
  }

  @media (max-width: 480px) {
    .stats__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .stats__label {
    display: block;
    font-family: var(--font-heading);
    font-weight: var(--fw-heading);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.6875rem;
    color: var(--wc-charcoal);
    opacity: 0.6;
    margin-bottom: 8px;
  }

  .stats__value {
    font-family: var(--font-heading);
    font-weight: var(--fw-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: 0.02em;
    color: var(--wc-charcoal);
  }

  /* Founder */
  .founder {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--block-spacing);
    align-items: start;
  }

  @media (min-width: 768px) {
    .founder {
      grid-template-columns: 2fr 3fr;
    }
  }

  .founder__photo {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    border-radius: var(--radius-block);
  }

  .founder__content h2 {
    margin-bottom: 4px;
  }

  .founder__content p {
    font-size: 0.9375rem;
    line-height: 1.8;
  }

  /* Approach */
  .approach {
    max-width: 720px;
  }

  .approach__body {
    margin-top: 20px;
    font-size: 1.0625rem;
    max-width: none;
  }

  /* CellPowerX Banner */
  .cpx-banner { position: relative; overflow: hidden; min-height: 420px; display: flex; align-items: center; justify-content: center; }
  .cpx-banner__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .cpx-banner__overlay { position: absolute; inset: 0; background: rgba(0, 0, 0, 0.55); }
  .cpx-banner__content { position: relative; z-index: 1; text-align: center; max-width: 640px; padding: var(--section-spacing) 20px; color: var(--wc-warm-white); }
  .cpx-banner__content h2 { color: var(--wc-warm-white); margin-bottom: 16px; }
  .cpx-banner__content p { font-size: 1rem; line-height: 1.5; opacity: 0.85; max-width: none; margin-bottom: 32px; }

  /* CTA Block */
  .cta-block {
    max-width: 640px;
  }

  .cta-block--centered {
    text-align: center;
    margin: 0 auto;
  }

  .cta-block--centered p {
    margin-left: auto;
    margin-right: auto;
  }
</style>
