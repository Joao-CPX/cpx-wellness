---
import Base from '../../layouts/Base.astro';
import { t, localeRoutes } from '../../i18n/utils';

const locale = 'en';
const i = t(locale);
const routes = localeRoutes[locale];
---

<Base title="Our Science" locale={locale} description="Understanding the science of cellular bioelectrics — the foundation of CellPowerX Wellness Center's frequency-based approach to well-being.">

  <!-- Hero -->
  <section class="page-hero section">
    <div class="container">
      <span class="label reveal">{i.ourScience.label}</span>
      <h1 class="reveal">{i.ourScience.heading}</h1>
      <p class="page-hero__body reveal">{i.ourScience.intro}</p>
    </div>
  </section>

  <!-- Tesla Quote -->
  <section class="section section--accent">
    <div class="container text-center">
      <blockquote class="quote reveal">
        <p class="quote__text">"{i.ourScience.teslaQuote}"</p>
        <footer class="quote__attribution">
          <strong>{i.ourScience.teslaAuthor}</strong>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Cells & Electricity -->
  <section class="section">
    <div class="container">
      <div class="science-section reveal">
        <h2>{i.ourScience.cellsHeading}</h2>
        <p>{i.ourScience.cellsBody}</p>
        <p>{i.ourScience.cellsBody2}</p>
      </div>
    </div>
  </section>

  <!-- Membrane Potential -->
  <section class="section section--accent">
    <div class="container">
      <div class="science-section reveal">
        <h2>{i.ourScience.membraneHeading}</h2>
        <p>{i.ourScience.membraneBody}</p>
        <div class="science-highlight section-block">
          <p>{i.ourScience.membraneHighlight}</p>
        </div>
        <p>{i.ourScience.membraneBody2}</p>
      </div>
    </div>
  </section>

  <!-- pH & Environment -->
  <section class="section">
    <div class="container">
      <div class="science-section reveal">
        <h2>{i.ourScience.phHeading}</h2>
        <p>{i.ourScience.phBody}</p>
        <p>{i.ourScience.phBody2}</p>
        <p>{i.ourScience.phBody3}</p>
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <section class="section section--accent">
    <div class="container">
      <div class="science-disclaimer reveal">
        <h3>{i.ourScience.disclaimerHeading}</h3>
        <p>{i.ourScience.disclaimer}</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-block cta-block--centered reveal">
        <h2>{i.ourScience.ctaHeading}</h2>
        <p style="margin-top: 16px; max-width: 620px;">{i.ourScience.ctaBody}</p>
        <a href={routes.contact} class="btn btn--cta" style="margin-top: 32px;">
          {i.ourScience.ctaCta}
          <i class="ph-light ph-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>

</Base>

<style>
  .page-hero {
    padding-top: calc(72px + var(--section-spacing));
  }

  .page-hero__body {
    font-size: 1.0625rem;
    max-width: 720px;
  }

  .quote {
    max-width: 720px;
    margin: 0 auto;
  }

  .quote__text {
    font-family: var(--font-body);
    font-weight: var(--fw-body);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.6;
    font-style: italic;
    max-width: none;
    margin-bottom: 24px;
  }

  .quote__attribution {
    font-size: 0.875rem;
    opacity: 0.5;
  }

  .science-section {
    max-width: 760px;
  }

  .science-section h2 {
    margin-bottom: 24px;
  }

  .science-section p {
    font-size: 1.0625rem;
    line-height: 1.8;
    max-width: none;
    margin-bottom: 20px;
  }

  .science-section p:last-child {
    margin-bottom: 0;
  }

  .science-highlight {
    margin: 32px 0;
    background: rgba(0, 0, 0, 0.03);
    border-left: 3px solid var(--cpx-secondary);
  }

  .science-highlight p {
    font-size: 1.0625rem;
    font-style: italic;
    margin-bottom: 0;
  }

  .science-disclaimer {
    max-width: 760px;
    padding: 32px;
    background: rgba(0, 0, 0, 0.03);
    border-radius: var(--radius-block);
  }

  .science-disclaimer h3 {
    margin-bottom: 12px;
    font-size: 0.875rem;
  }

  .science-disclaimer p {
    font-size: 0.875rem;
    line-height: 1.7;
    opacity: 0.6;
    max-width: none;
  }

  .cta-block--centered {
    text-align: center;
  }

  .cta-block--centered p {
    margin-left: auto;
    margin-right: auto;
  }
</style>
