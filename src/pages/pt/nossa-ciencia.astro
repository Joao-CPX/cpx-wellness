---
import Base from '../../layouts/Base.astro';
import { t, localeRoutes } from '../../i18n/utils';

const locale = 'pt';
const i = t(locale);
const routes = localeRoutes[locale];
---

<Base title="A Nossa Ciência" locale={locale} description="Compreender a ciência da bioelectricidade celular - a base da abordagem do CellPowerX Wellness Center ao bem-estar baseado em frequências.">

  <!-- Hero -->
  <section class="page-hero section">
    <div class="container">
      <span class="label reveal">{i.ourScience.label}</span>
      <h1 class="reveal">{i.ourScience.heading}</h1>
      <p class="page-hero__body reveal">{i.ourScience.intro}</p>
    </div>
  </section>

  <!-- Tesla Quote -->
  <section class="section section--accent">
    <div class="container text-center">
      <blockquote class="quote reveal">
        <p class="quote__text">"{i.ourScience.teslaQuote}"</p>
        <footer class="quote__attribution">
          <img src="/images/Tesla.jpg" alt="Nikola Tesla" class="quote__avatar" />
          <strong>{i.ourScience.teslaAuthor}</strong>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Tabs Section -->
  <section class="section">
    <div class="container">
      <div class="science-tabs reveal">
        <div class="science-tabs__nav">
          <button class="science-tabs__btn is-active" data-tab="tab-cells">{i.ourScience.tab1}</button>
          <button class="science-tabs__btn" data-tab="tab-ions">{i.ourScience.tab2}</button>
          <button class="science-tabs__btn" data-tab="tab-membrane">{i.ourScience.tab3}</button>
        </div>
        <div class="science-tabs__panels">
          <!-- Tab 1: Cells -->
          <div class="science-tabs__panel is-active" id="tab-cells">
            <h2>{i.ourScience.cellsHeading}</h2>
            <p>{i.ourScience.cellsBody}</p>
            <p>{i.ourScience.cellsBody2}</p>
          </div>
          <!-- Tab 2: Ions -->
          <div class="science-tabs__panel" id="tab-ions">
            <h2>{i.ourScience.ionsHeading}</h2>
            <p>{i.ourScience.ionsBody}</p>
            <p>{i.ourScience.ionsBody2}</p>
            <div class="science-disclaimer">
              <p><strong>{i.ourScience.disclaimerTitle}</strong><br/>{i.ourScience.disclaimerNote}</p>
            </div>
          </div>
          <!-- Tab 3: Membrane Reference -->
          <div class="science-tabs__panel" id="tab-membrane">
            <h2>{i.ourScience.membraneHeading}</h2>
            <p>{i.ourScience.membraneBody}</p>
            <h3>{i.ourScience.internalHeading}</h3>
            <p>{i.ourScience.internalBody}</p>
            <p class="science-closing">{i.ourScience.internalBody2}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cellular Bioelectrical Activity -->
  <section class="section section--accent">
    <div class="container">
      <h2 class="text-center reveal">{i.ourScience.activityHeading}</h2>
      <p class="science-intro reveal">{i.ourScience.activityIntro}</p>
      <div class="science-row reveal">
        <div class="science-row__text">
          <div class="science-border-block">
            <p>{i.ourScience.activityBody}</p>
            <p>{i.ourScience.activityBody2}</p>
          </div>
          <p class="science-note">{i.ourScience.activityBody3}</p>
        </div>
        <div class="science-row__img">
          <img src="/images/Cellular-bioelectrical-activity.jpg" alt="Atividade bioelétrica celular e potencial de membrana" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Key Statement -->
  <section class="section science-statement">
    <div class="container text-center">
      <p class="reveal">{i.ourScience.keyStatement}</p>
      <p class="reveal">{i.ourScience.keyStatementBody}</p>
      <p class="science-statement__highlight reveal">{i.ourScience.keyStatementHighlight}</p>
    </div>
  </section>

  <!-- Natural Cellular Cycles -->
  <section class="section">
    <div class="container">
      <div class="science-row science-row--reverse reveal">
        <div class="science-row__text">
          <div class="science-border-block">
            <p>{i.ourScience.cyclesBody}</p>
            <p>{i.ourScience.cyclesBody2}</p>
          </div>
          <p class="science-note">{i.ourScience.cyclesBody3}</p>
        </div>
        <div class="science-row__img">
          <img src="/images/natural-cycles-of-electrical-variation.jpg" alt="Ciclos naturais de variação elétrica" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Acid vs Alkaline -->
  <section class="section science-statement">
    <div class="container">
      <h2 class="text-center reveal">{i.ourScience.phHeading}</h2>
      <div class="text-center reveal">
        <p>{i.ourScience.phBody}</p>
        <p>{i.ourScience.phBody2}</p>
        <p>{i.ourScience.phBody3}</p>
      </div>
      <div class="science-diagram reveal">
        <img src="/images/Acid-Medium-vs.-Alkaline-Medium.jpg" alt="Meio Ácido vs. Meio Alcalino" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-block cta-block--centered reveal">
        <h2>{i.ourScience.ctaHeading}</h2>
        <p style="margin-top: 16px; max-width: 620px;">{i.ourScience.ctaBody}</p>
        <a href={routes.contact} class="btn btn--cta" style="margin-top: 32px;">
          {i.ourScience.ctaCta}
          <i class="ph-light ph-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>

</Base>

<style is:global>
  .page-hero {
    padding-top: calc(72px + var(--section-spacing));
    text-align: center;
  }

  .page-hero h1 { margin-bottom: 24px; }

  .page-hero__body {
    font-size: 1.0625rem;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Tabs */
  .science-tabs__nav {
    display: flex;
    gap: 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    margin-bottom: 48px;
  }

  .science-tabs__btn {
    flex: 1;
    padding: 16px 24px;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 400;
    color: rgba(0, 0, 0, 0.4);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
  }

  .science-tabs__btn:hover { color: var(--wc-charcoal); }

  .science-tabs__btn.is-active {
    color: var(--wc-charcoal);
    border-bottom-color: var(--cpx-secondary);
    font-weight: 500;
  }

  .science-tabs__panel { display: none; max-width: 800px; }
  .science-tabs__panel.is-active { display: block; }
  .science-tabs__panel h2 { margin-bottom: 24px; }
  .science-tabs__panel h3 { margin-top: 32px; margin-bottom: 16px; }
  .science-tabs__panel p { font-size: 1.0625rem; line-height: 1.7; margin-bottom: 16px; }
  .science-closing { margin-top: 8px; font-style: italic; opacity: 0.7; }

  .science-disclaimer {
    margin-top: 32px;
    padding: 24px;
    background: rgba(0, 0, 0, 0.03);
    border-radius: var(--radius-block);
  }

  .science-disclaimer p { font-size: 0.875rem; line-height: 1.6; opacity: 0.6; margin-bottom: 0; }

  .science-intro {
    text-align: center;
    max-width: 900px;
    margin: 16px auto 48px;
    font-size: 1.0625rem;
    line-height: 1.7;
  }

  .science-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--block-spacing);
    align-items: center;
  }

  @media (min-width: 768px) {
    .science-row { grid-template-columns: 3fr 2fr; }
    .science-row--reverse { grid-template-columns: 2fr 3fr; }
    .science-row--reverse .science-row__img { order: -1; }
  }

  .science-row__img { overflow: hidden; border-radius: var(--radius-block); }
  .science-row__img img { width: 100%; border-radius: var(--radius-block); object-fit: cover; }

  .science-border-block {
    border-left: 3px solid var(--cpx-secondary);
    padding-left: 24px;
    margin-bottom: 24px;
  }

  .science-border-block p { font-size: 1.0625rem; line-height: 1.7; margin-bottom: 16px; }
  .science-border-block p:last-child { margin-bottom: 0; }
  .science-note { font-size: 1.0625rem; line-height: 1.7; margin-top: 24px; }

  .science-statement { background: rgba(0, 0, 0, 0.03); }

  .science-statement p {
    font-size: 1.0625rem;
    line-height: 1.7;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 12px;
  }

  .science-statement h2 { margin-bottom: 24px; }

  .science-statement__highlight {
    font-size: 1.25rem !important;
    font-weight: 600;
    color: #b5a06e;
    margin-top: 16px !important;
  }

  .science-diagram { margin-top: 48px; text-align: center; }
  .science-diagram img { max-width: 800px; width: 100%; border-radius: var(--radius-block); }

  .quote { max-width: 720px; margin: 0 auto; }
  .quote__text {
    font-family: var(--font-body);
    font-weight: var(--fw-body);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.5;
    font-style: italic;
    max-width: none;
    margin-bottom: 24px;
  }
  .quote__attribution { display: flex; align-items: center; justify-content: center; gap: 12px; font-size: 0.875rem; }
  .quote__attribution strong { opacity: 0.5; }
  .quote__avatar { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; }

  .cta-block--centered { text-align: center; }
  .cta-block--centered p { margin-left: auto; margin-right: auto; }
</style>

<script>
  const tabs = document.querySelectorAll('.science-tabs__btn');
  const panels = document.querySelectorAll('.science-tabs__panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('is-active'));
      panels.forEach(p => p.classList.remove('is-active'));
      tab.classList.add('is-active');
      const target = document.getElementById(tab.dataset.tab);
      if (target) target.classList.add('is-active');
    });
  });
</script>
