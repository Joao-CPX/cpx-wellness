---
import { t, localeRoutes } from '../i18n/utils';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const i = t(locale);
const routes = localeRoutes[locale];
---

<footer class="footer">
  <div class="container">
    <!-- Logo row -->
    <div class="footer__logo-row">
      <div class="footer__logo">
        <img src="/images/cpx-logo.svg" alt="CellPowerX" class="footer__logo-img" />
        <span class="footer__logo-links">
          <a href={routes.home}>Wellness Center</a>
          <span class="footer__logo-divider">|</span>
          <a href="https://www.cellpowerx.com" target="_blank" rel="noopener">Wellness Devices</a>
        </span>
      </div>
    </div>

    <!-- 3-column grid -->
    <div class="footer__grid">
      <!-- Column 1: Links -->
      <div class="footer__col">
        <h4 class="footer__heading">{i.footer.linksHeading}</h4>
        <nav class="footer__links">
          <a href={routes.treatments}>{i.nav.treatments}</a>
          <a href={routes.ourScience}>{i.nav.ourScience}</a>
          <a href={routes.about}>{i.nav.about}</a>
          <a href={routes.contact}>{i.nav.contact}</a>
          <a href={routes.privacy}>{i.footer.privacy}</a>
          <a href={routes.terms}>{i.footer.terms}</a>
          <a href="https://www.livroreclamacoes.pt/Pedido/Reclamacao" target="_blank" rel="noopener">{i.footer.complaintsBook}</a>
          <a href="#" id="cookie-preferences-link">{locale === 'pt' ? 'Preferências de Cookies' : 'Cookie Preferences'}</a>
        </nav>
      </div>

      <!-- Column 2: Contact -->
      <div class="footer__col">
        <h4 class="footer__heading">{i.footer.contactHeading}</h4>
        <div class="footer__contact-list">
          <div class="footer__contact-item">
            <i class="ph-light ph-phone"></i>
            <a href={`tel:${i.contact.phone.replace(/\s/g, '')}`}>{i.contact.phone}</a>
          </div>
          <div class="footer__contact-item">
            <i class="ph-light ph-whatsapp-logo"></i>
            <a href={`https://wa.me/${i.contact.phoneMobile.replace(/[+\s]/g, '')}`}>{i.contact.phoneMobile}</a>
          </div>
          <div class="footer__contact-item">
            <i class="ph-light ph-envelope-simple"></i>
            <a href={`mailto:${i.contact.email}`}>{i.contact.email}</a>
          </div>
          <div class="footer__contact-item">
            <i class="ph-light ph-map-pin"></i>
            <span>{i.contact.address}<br />{i.contact.addressCity}</span>
          </div>
          <div class="footer__contact-item">
            <i class="ph-light ph-clock"></i>
            <span>{i.contact.hours.monThu}<br />{i.contact.hours.fri}<br />{i.contact.hours.weekend}</span>
          </div>
        </div>
      </div>

      <!-- Column 3: Newsletter -->
      <div class="footer__col footer__col--newsletter">
        <h4 class="footer__heading">{i.footer.newsletterHeading}</h4>
        <p class="footer__newsletter-body">{i.footer.newsletterBody}</p>
        <form class="footer__newsletter-form" id="newsletter-form">
          <input type="email" class="footer__newsletter-input" id="newsletter-email" placeholder={i.footer.newsletterPlaceholder} required />
          <label class="footer__consent">
            <input type="checkbox" required />
            <span set:html={i.footer.consentText} />
          </label>
          <button type="submit" class="btn btn--cta footer__newsletter-btn" id="newsletter-btn">{i.footer.newsletterCta}</button>
          <p class="footer__newsletter-msg" id="newsletter-msg"></p>
        </form>
      </div>
    </div>

    <!-- Bottom -->
    <div class="footer__bottom">
      <div class="footer__bottom-row">
        <p>&copy; {new Date().getFullYear()} CellPowerX Wellness Center. {i.footer.rights}<br />ERS License n. E176530 - Clinical leadership by Nuno Nina (ACSS 0300169)</p>
        <div class="footer__socials">
          <a href="https://www.instagram.com/cellpowerx/" target="_blank" rel="noopener" aria-label="Instagram">
            <i class="ph-light ph-instagram-logo"></i>
          </a>
          <a href="https://www.facebook.com/ImIntegrativeMedicine/" target="_blank" rel="noopener" aria-label="Facebook">
            <i class="ph-light ph-facebook-logo"></i>
          </a>
          <a href="https://www.youtube.com/user/IMclinic/videos" target="_blank" rel="noopener" aria-label="YouTube">
            <i class="ph-light ph-youtube-logo"></i>
          </a>
          <a href="https://pt.linkedin.com/company/im-integrative-medicine" target="_blank" rel="noopener" aria-label="LinkedIn">
            <i class="ph-light ph-linkedin-logo"></i>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style is:global>
  .footer {
    background: var(--cpx-dark-bg);
    color: rgba(250, 248, 245, 0.7);
    padding: clamp(48px, 6vw, 80px) 0 clamp(24px, 3vw, 40px);
  }

  /* Logo row */
  .footer__logo-row {
    margin-bottom: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(195, 214, 221, 0.12);
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .footer__logo-img {
    height: 28px;
    width: auto;
    filter: invert(1);
  }

  .footer__logo-links {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 1rem;
    letter-spacing: 0.02em;
  }

  .footer__logo-links a {
    color: var(--wc-warm-white);
    opacity: 0.5;
    transition: opacity 0.2s ease;
  }

  .footer__logo-links a:hover {
    opacity: 1;
  }

  .footer__logo-divider {
    color: var(--wc-warm-white);
    opacity: 0.25;
  }

  /* 3-column grid */
  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    margin-bottom: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(195, 214, 221, 0.08);
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr 1.5fr;
    }
  }

  .footer__heading {
    font-family: var(--font-heading);
    font-weight: var(--fw-heading);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.8125rem;
    color: var(--wc-warm-white);
    margin-bottom: 20px;
  }

  /* Links column */
  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__links a {
    font-size: 0.875rem;
    color: rgba(250, 248, 245, 0.5);
    transition: color 0.2s ease;
  }

  .footer__links a:hover {
    color: var(--wc-warm-white);
  }

  /* Contact column */
  .footer__contact-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__contact-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 0.875rem;
  }

  .footer__contact-item i {
    color: var(--cpx-accent);
    font-size: 1rem;
    margin-top: 2px;
    flex-shrink: 0;
  }

  .footer__contact-item a:hover {
    color: var(--wc-warm-white);
  }

  /* Newsletter column */
  .footer__col--newsletter {
    text-align: center;
  }

  .footer__newsletter-body {
    font-size: 0.875rem;
    margin-bottom: 16px;
    max-width: none;
  }

  .footer__newsletter-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .footer__newsletter-input {
    width: 100%;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(195, 214, 221, 0.2);
    border-radius: var(--radius-input);
    color: var(--wc-warm-white);
    font-size: 0.875rem;
    font-family: var(--font-body);
    outline: none;
    transition: border-color 0.2s ease;
  }

  .footer__newsletter-input::placeholder {
    color: rgba(250, 248, 245, 0.3);
  }

  .footer__newsletter-input:focus {
    border-color: var(--cpx-accent);
  }

  .footer__consent {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 0.75rem;
    color: rgba(250, 248, 245, 0.5);
    line-height: 1.5;
    text-align: left;
    cursor: pointer;
  }

  .footer__consent input[type="checkbox"] {
    flex-shrink: 0;
    margin-top: 2px;
    accent-color: var(--cpx-secondary);
  }

  .footer__consent a {
    color: rgba(250, 248, 245, 0.7);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer__consent a:hover {
    color: var(--wc-warm-white);
  }

  .footer__newsletter-btn {
    width: fit-content;
    padding: 10px 24px;
    font-size: 0.75rem;
  }

  /* Logo links mobile spacing */
  @media (max-width: 767px) {
    .footer__logo {
      flex-wrap: wrap;
      gap: 6px;
    }
    .footer__logo-links {
      font-size: 0.8125rem;
      gap: 6px;
    }
  }

  .footer__newsletter-msg {
    font-size: 0.8125rem;
    margin-top: 8px;
    min-height: 1.2em;
  }

  .footer__newsletter-msg--success {
    color: #4ade80;
  }

  .footer__newsletter-msg--error {
    color: var(--cpx-secondary);
  }

  /* Bottom */
  .footer__bottom-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer__bottom p {
    font-size: 0.75rem;
    color: rgba(250, 248, 245, 0.35);
  }

  .footer__socials {
    display: flex;
    gap: 16px;
  }

  .footer__socials a {
    font-size: 1.5rem;
    color: rgba(250, 248, 245, 0.35);
    transition: color 0.2s ease;
  }

  .footer__socials a:hover {
    color: var(--wc-warm-white);
  }

  @media (max-width: 767px) {
    .footer__bottom-row {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }
</style>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const emailInput = document.getElementById('newsletter-email') as HTMLInputElement | null;
  const btn = document.getElementById('newsletter-btn') as HTMLButtonElement | null;
  const msg = document.getElementById('newsletter-msg');
  const lang = document.documentElement.lang;

  const texts = {
    sending: lang === 'pt' ? 'A enviar...' : 'Sending...',
    success: lang === 'pt' ? 'Subscrito com sucesso!' : 'Successfully subscribed!',
    existing: lang === 'pt' ? 'Este email já está subscrito.' : 'This email is already subscribed.',
    error: lang === 'pt' ? 'Ocorreu um erro. Tente novamente.' : 'Something went wrong. Please try again.',
    subscribe: lang === 'pt' ? 'Subscrever' : 'Subscribe',
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!emailInput || !btn || !msg) return;

    const email = emailInput.value.trim();
    if (!email) return;

    btn.disabled = true;
    btn.textContent = texts.sending;
    msg.textContent = '';
    msg.className = 'footer__newsletter-msg';

    try {
      const res = await fetch('https://cpx-newsletter-api.joao-relego.workers.dev', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      const data = await res.json();

      if (data.success) {
        msg.textContent = data.existing ? texts.existing : texts.success;
        msg.classList.add('footer__newsletter-msg--success');
        emailInput.value = '';
      } else {
        msg.textContent = texts.error;
        msg.classList.add('footer__newsletter-msg--error');
      }
    } catch {
      msg.textContent = texts.error;
      msg.classList.add('footer__newsletter-msg--error');
    } finally {
      btn.disabled = false;
      btn.textContent = texts.subscribe;
    }
  });
</script>
