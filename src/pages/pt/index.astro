---
import Base from '../../layouts/Base.astro';
import { t, localeRoutes } from '../../i18n/utils';

const locale = 'pt';
const i = t(locale);
const routes = localeRoutes[locale];
---

<Base title="Bem-Estar Baseado em Frequências em Lisboa" locale={locale} description="CellPowerX Wellness Center — O centro pioneiro de bem-estar em Lisboa baseado em frequências. 20+ anos de experiência, 70.000+ percursos de clientes.">

  <!-- Hero -->
  <section class="hero">
    <img src="/images/hero.webp" alt="Nuno Nina a trabalhar com o TimeWaver no CellPowerX Wellness Center" class="hero__bg" loading="eager" />
    <div class="hero__overlay"></div>
    <div class="container hero__inner">
      <div class="hero__content">
        <span class="label reveal">{i.hero.label}</span>
        <h1 class="reveal">{i.hero.heading}</h1>
        <p class="hero__body reveal">{i.hero.body}</p>
        <div class="hero__actions reveal">
          <a href={routes.contact} class="btn hero__btn-primary">
            {i.hero.ctaPrimary}
            <i class="ph-light ph-arrow-right"></i>
          </a>
          <a href={routes.treatments} class="btn btn--secondary hero__btn-secondary">
            {i.hero.ctaSecondary}
            <i class="ph-light ph-arrow-right"></i>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Value Props -->
  <section class="section section--accent">
    <div class="container">
      <div class="grid-3" data-stagger>
        <div class="card">
          <div class="card__icon">
            <i class="ph-light ph-dna" style="font-size: 2.5rem;"></i>
          </div>
          <h3>{i.valueProps.card1Title}</h3>
          <p>{i.valueProps.card1Text}</p>
        </div>
        <div class="card">
          <div class="card__icon">
            <i class="ph-light ph-circuitry" style="font-size: 2.5rem;"></i>
          </div>
          <h3>{i.valueProps.card2Title}</h3>
          <p>{i.valueProps.card2Text}</p>
        </div>
        <div class="card">
          <div class="card__icon">
            <i class="ph-light ph-users-three" style="font-size: 2.5rem;"></i>
          </div>
          <h3>{i.valueProps.card3Title}</h3>
          <p>{i.valueProps.card3Text}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Treatments Preview -->
  <section class="section">
    <div class="container">
      <h2 class="text-center reveal" style="margin-bottom: var(--block-spacing);">
        {i.treatmentsPreview.heading}
      </h2>
      <div class="grid-4 services-carousel" data-stagger>
        {[
          { key: 'slmwave', img: '/images/slmwave.png', pos: 'center center' },
          { key: 'nanopulse', img: '/images/nanopulse.png', pos: 'left center' },
          { key: 'infrared', img: '/images/redlight.png', pos: 'center center' },
          { key: 'timewaver', img: '/images/timewaver.png', pos: 'right center' },
        ].map(({ key, img, pos }) => (
          <a href={`${routes.treatments}#${key}`} class="service-card">
            <div class="service-card__img-wrap">
              <img src={img} alt={i.treatmentsPreview[key].name} class="service-card__img" style={`object-position: ${pos};`} loading="lazy" />
            </div>
            <div class="service-card__text">
              <h4>{i.treatmentsPreview[key].name}</h4>
              <p>{i.treatmentsPreview[key].tagline}</p>
              <span class="service-card__link">{i.treatmentsPreview.learnMore} <i class="ph-light ph-arrow-right"></i></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <section class="section">
    <div class="container">
      <div class="google-reviews reveal">
        <div class="google-reviews__stars">
          <i class="ph-fill ph-star"></i>
          <i class="ph-fill ph-star"></i>
          <i class="ph-fill ph-star"></i>
          <i class="ph-fill ph-star"></i>
          <i class="ph-fill ph-star"></i>
        </div>
        <p class="google-reviews__rating">
          <strong>4.9</strong> <span>— Google Reviews (15)</span>
        </p>
        <a href="https://maps.app.goo.gl/CYtvtkwpFCRzgY76A" target="_blank" rel="noopener" class="google-reviews__link">
          Deixar uma Review <i class="ph-light ph-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- Quote -->
  <section class="section section--accent">
    <div class="container text-center">
      <blockquote class="quote reveal">
        <p class="quote__text">"{i.quote.text}"</p>
        <footer class="quote__attribution">
          <strong>{i.quote.author}</strong> — {i.quote.role}
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- First Appointment CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-block cta-block--centered reveal">
        <h2>{i.firstAppointment.heading}</h2>
        <p class="cta-block__body">{i.firstAppointment.body}</p>
        <a href={routes.contact} class="btn btn--cta" style="margin-top: 32px;">
          {i.firstAppointment.cta}
          <i class="ph-light ph-arrow-right"></i>
        </a>
        <div class="cta-block__location">
          <i class="ph-light ph-map-pin"></i>
          <span>{i.firstAppointment.location} · {i.firstAppointment.locationDetail}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CellPowerX Ecosystem -->
  <section class="cpx-banner reveal">
    <img src="https://www.cellpowerx.com/cdn/shop/files/Wellness_is_evolving_3200x1600_baec34e8-3d1e-4ed4-b8e1-636cd2ec8610.webp?v=1767977609&width=3000" alt="CellPowerX Ecosystem" class="cpx-banner__img" loading="lazy" />
    <div class="cpx-banner__overlay"></div>
    <div class="cpx-banner__content">
      <h2>{i.about.ecosystemHeading}</h2>
      <p>{i.about.ecosystemBody}</p>
      <a href="https://www.cellpowerx.com" target="_blank" rel="noopener" class="btn btn--cta">
        {i.about.ecosystemCta}
        <i class="ph-light ph-arrow-up-right"></i>
      </a>
    </div>
  </section>


</Base>

<style>
  .hero {
    position: relative;
    padding: var(--section-spacing) 0;
    margin-top: 72px;
    min-height: 500px;
    max-height: 640px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero__bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center top;
  }
  .hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to right, rgba(0, 0, 0, 0.65), rgba(0, 0, 0, 0));
  }
  @media (max-width: 767px) {
    .hero__overlay { background: rgba(0, 0, 0, 0.5); }
  }
  .hero__inner { position: relative; z-index: 1; }
  .hero__content {
    display: flex; flex-direction: column;
    gap: var(--element-spacing); max-width: 640px;
  }
  .hero .label { color: var(--cpx-accent); }
  .hero h1 { color: var(--wc-warm-white); }
  .hero__body { font-size: 1.0625rem; line-height: 1.5; max-width: 520px; color: rgba(250, 248, 245, 0.85); }
  .hero__actions { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 8px; }
  .hero__btn-primary { background: var(--cpx-secondary); color: #ffffff; border: none; }
  .hero__btn-primary:hover { background: #e03d12; box-shadow: 0 8px 24px rgba(251, 70, 22, 0.3); }
  .hero__btn-secondary { border-color: rgba(250, 248, 245, 0.3); color: var(--wc-warm-white); }
  .hero__btn-secondary:hover { background: var(--cpx-secondary); color: #ffffff; border-color: var(--cpx-secondary); }

  @media (max-width: 767px) {
    .services-carousel {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 16px;
      padding-bottom: 8px;
      margin-left: -20px;
      margin-right: -20px;
      padding-left: 20px;
      padding-right: 20px;
    }
    .services-carousel::-webkit-scrollbar { display: none; }
    .services-carousel .service-card { flex: 0 0 72%; scroll-snap-align: start; }
  }

  .service-card { display: flex; flex-direction: column; text-decoration: none; }
  .service-card__img-wrap { border-radius: var(--radius-block); overflow: hidden; aspect-ratio: 3/4; background: var(--wc-mist); }
  .service-card__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .service-card:hover .service-card__img { transform: scale(1.03); }
  .service-card__text { padding-top: 16px; }
  .service-card__text h4 { margin-bottom: 6px; }
  .service-card__text p { font-size: 0.875rem; color: var(--wc-charcoal); opacity: 0.6; line-height: 1.5; }
  .service-card__link {
    display: inline-flex; align-items: center; gap: 4px;
    margin-top: 10px; font-size: 0.8125rem; color: var(--cpx-accent);
    transition: color 0.2s ease;
  }
  .service-card:hover .service-card__link { color: var(--cpx-secondary); }

  .google-reviews { display: flex; flex-direction: column; align-items: center; gap: 8px; text-align: center; }
  .google-reviews__stars { display: flex; gap: 2px; font-size: 1.25rem; color: #FBBC04; }
  .google-reviews__rating { font-size: 1rem; color: var(--wc-charcoal); margin: 0; max-width: none; }
  .google-reviews__rating strong { font-size: 1.125rem; }
  .google-reviews__rating span { opacity: 0.5; }
  .google-reviews__link { display: inline-flex; align-items: center; gap: 4px; font-size: 0.8125rem; color: var(--cpx-accent); transition: color 0.2s ease; }
  .google-reviews__link:hover { color: var(--cpx-secondary); }

  .quote {
    max-width: 720px;
    margin: 0 auto;
  }

  .quote__text {
    font-family: var(--font-body);
    font-weight: var(--fw-body);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.6;
    font-style: italic;
    max-width: none;
    margin-bottom: 24px;
  }

  .quote__attribution {
    font-family: var(--font-heading);
    font-weight: var(--fw-heading);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
  }

  .cpx-banner { position: relative; overflow: hidden; min-height: 420px; display: flex; align-items: center; justify-content: center; }
  .cpx-banner__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .cpx-banner__overlay { position: absolute; inset: 0; background: rgba(0, 0, 0, 0.55); }
  .cpx-banner__content { position: relative; z-index: 1; text-align: center; max-width: 640px; padding: var(--section-spacing) 20px; color: var(--wc-warm-white); }
  .cpx-banner__content h2 { color: var(--wc-warm-white); margin-bottom: 16px; }
  .cpx-banner__content p { font-size: 1rem; line-height: 1.7; opacity: 0.85; max-width: none; margin-bottom: 32px; }

  .cta-block { max-width: 640px; }
  .cta-block--centered { text-align: center; margin: 0 auto; }
  .cta-block--centered p { margin-left: auto; margin-right: auto; }
  .cta-block--centered .cta-block__location { justify-content: center; }

  .cta-block__body {
    font-size: 1.0625rem;
    margin-top: 16px;
    max-width: none;
  }

  .cta-block__location {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 24px;
    font-size: 0.875rem;
    color: var(--wc-sage);
  }

  .cta-block__location i {
    color: var(--cpx-accent);
  }

  .newsletter h2 { margin-bottom: 12px; }
  .newsletter p { margin-bottom: 32px; }

  .newsletter__form {
    display: flex;
    gap: 12px;
    max-width: 480px;
    margin: 0 auto;
  }

  .newsletter__form .input { flex: 1; }

  .newsletter__input {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(195, 214, 221, 0.25);
    color: var(--wc-warm-white);
  }
  .newsletter__input::placeholder { color: rgba(250, 248, 245, 0.35); }
  .newsletter__input:focus {
    border-color: var(--cpx-accent);
    background: rgba(255, 255, 255, 0.12);
  }

  @media (max-width: 480px) {
    .newsletter__form { flex-direction: column; }
  }
</style>
