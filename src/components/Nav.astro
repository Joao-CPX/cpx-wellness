---
import { t, localeRoutes } from '../i18n/utils';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const i = t(locale);
const routes = localeRoutes[locale];
const altLocale = locale === 'en' ? 'pt' : 'en';
const altRoutes = localeRoutes[altLocale];

// Determine matching routes for both languages
const currentPath = Astro.url.pathname;
let altPath = altRoutes.home;
let currentKey = 'home';
for (const [key, path] of Object.entries(routes)) {
  if (currentPath === path || currentPath === path + '/') {
    altPath = altRoutes[key];
    currentKey = key;
    break;
  }
}
const enPath = locale === 'en' ? currentPath : altPath;
const ptPath = locale === 'pt' ? currentPath : altPath;

const serviceItems = [
  { key: 'slmwave', name: i.treatments.slmwave.name },
  { key: 'nanopulse', name: i.treatments.nanopulse.name },
  { key: 'infrared', name: i.treatments.infrared.name },
  { key: 'timewaver', name: i.treatments.timewaver.name },
];
---

<header class="nav" id="nav">
  <div class="nav__inner container">
    <!-- Mobile: hamburger left -->
    <button class="nav__hamburger hide-desktop" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <!-- Logo (centered on mobile) -->
    <a href={routes.home} class="nav__logo">
      <img src="/images/cpx-logo.svg" alt="CellPowerX" class="nav__logo-img" />
      <span class="nav__logo-text hide-mobile">Wellness Center</span>
    </a>
    <span class="nav__logo-subtitle hide-desktop">Wellness Center</span>

    <!-- Desktop nav links -->
    <nav class="nav__links hide-mobile" aria-label="Main navigation">
      <div class="nav__dropdown" id="services-dropdown">
        <a href={routes.treatments} class="nav__dropdown-trigger">
          {i.nav.treatments}
          <i class="ph ph-caret-down nav__dropdown-caret"></i>
        </a>
        <div class="nav__dropdown-menu" aria-hidden="true">
          {serviceItems.map(({ key, name }) => (
            <a href={`${routes.treatments}#${key}`} class="nav__dropdown-item">{name}</a>
          ))}
        </div>
      </div>
      <a href={routes.about}>{i.nav.about}</a>
      <a href={routes.contact}>{i.nav.contact}</a>
    </nav>

    <!-- Right side actions -->
    <div class="nav__actions">
      <div class="nav__lang-dropdown" id="lang-dropdown">
        <button class="nav__lang-trigger" aria-expanded="false" aria-haspopup="true">
          <i class="ph ph-globe-simple"></i>
          <i class="ph ph-caret-down nav__lang-caret hide-mobile"></i>
        </button>
        <div class="nav__lang-menu" aria-hidden="true">
          <a href={enPath} class={`nav__lang-option ${locale === 'en' ? 'is-active' : ''}`}>English</a>
          <a href={ptPath} class={`nav__lang-option ${locale === 'pt' ? 'is-active' : ''}`}>Português</a>
        </div>
      </div>
      <a href={routes.contact} class="btn btn--primary nav__cta hide-mobile">
        {i.nav.bookNow}
        <i class="ph ph-arrow-right"></i>
      </a>
    </div>
  </div>

  <!-- Mobile overlay -->
  <div class="nav__mobile" id="nav-mobile" aria-hidden="true">
    <button class="nav__mobile-close" id="nav-close" aria-label="Close menu">
      <i class="ph ph-x" style="font-size: 1.5rem;"></i>
    </button>
    <nav class="nav__mobile-links">
      <div class="nav__mobile-group">
        <a href={routes.treatments} class="nav__mobile-heading">{i.nav.treatments}</a>
        <div class="nav__mobile-sub">
          {serviceItems.map(({ key, name }) => (
            <a href={`${routes.treatments}#${key}`}>{name}</a>
          ))}
        </div>
      </div>
      <a href={routes.about}>{i.nav.about}</a>
      <a href={routes.contact}>{i.nav.contact}</a>
      <a href={routes.contact} class="btn btn--cta nav__mobile-cta">
        {i.nav.bookNow}
        <i class="ph ph-arrow-right"></i>
      </a>
      <div class="nav__mobile-socials">
        <a href="https://www.instagram.com/cellpowerx/" target="_blank" rel="noopener" aria-label="Instagram">
          <i class="ph ph-instagram-logo"></i>
        </a>
        <a href="https://www.facebook.com/ImIntegrativeMedicine/" target="_blank" rel="noopener" aria-label="Facebook">
          <i class="ph ph-facebook-logo"></i>
        </a>
        <a href="https://www.youtube.com/user/IMclinic/videos" target="_blank" rel="noopener" aria-label="YouTube">
          <i class="ph ph-youtube-logo"></i>
        </a>
        <a href="https://pt.linkedin.com/company/im-integrative-medicine" target="_blank" rel="noopener" aria-label="LinkedIn">
          <i class="ph ph-linkedin-logo"></i>
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  /* === Base nav === */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid rgba(195, 214, 221, 0.15);
    transition: background 0.4s ease, border-color 0.4s ease;
  }

  /* Light mode (default) */
  .nav {
    background: rgba(250, 248, 245, 0.72);
    border-bottom-color: rgba(195, 214, 221, 0.15);
  }

  /* Dark mode — toggled via JS */
  .nav.nav--dark {
    background: rgba(29, 29, 31, 0.72);
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    height: 72px;
  }

  /* === Logo === */
  .nav__logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav__logo-img {
    height: 28px;
    width: auto;
    transition: filter 0.4s ease;
  }

  .nav--dark .nav__logo-img {
    filter: invert(1);
  }

  .nav__logo-text {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 1rem;
    letter-spacing: 0.02em;
    color: var(--wc-charcoal);
    opacity: 0.5;
    transition: color 0.4s ease, opacity 0.4s ease;
  }

  .nav--dark .nav__logo-text {
    color: var(--wc-warm-white);
    opacity: 0.5;
  }

  /* === Nav links === */
  .nav__links {
    display: flex;
    gap: 36px;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .nav__links a {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.9375rem;
    color: var(--wc-charcoal);
    transition: color 0.4s ease;
  }

  .nav__links a:hover {
    color: var(--cpx-secondary);
  }

  .nav--dark .nav__links a {
    color: rgba(250, 248, 245, 0.8);
  }

  .nav--dark .nav__links a:hover {
    color: var(--wc-warm-white);
  }

  /* === Services dropdown === */
  .nav__dropdown {
    position: relative;
  }

  .nav__dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 4px;
    cursor: pointer;
  }

  .nav__dropdown-caret {
    font-size: 0.7rem;
    transition: transform 0.2s ease;
  }

  .nav__dropdown:hover .nav__dropdown-caret {
    transform: rotate(180deg);
  }

  .nav__dropdown-menu {
    position: absolute;
    top: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(-4px);
    min-width: 200px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(195, 214, 221, 0.2);
    border-radius: 8px;
    padding: 6px 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .nav__dropdown:hover .nav__dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .nav--dark .nav__dropdown-menu {
    background: rgba(29, 29, 31, 0.95);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .nav__dropdown-item {
    display: block;
    padding: 8px 20px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--wc-charcoal);
    transition: background 0.15s ease;
    text-transform: none;
    letter-spacing: 0;
  }

  .nav__dropdown-item:hover {
    background: rgba(195, 214, 221, 0.15);
  }

  .nav--dark .nav__dropdown-item {
    color: rgba(250, 248, 245, 0.8);
  }

  .nav--dark .nav__dropdown-item:hover {
    background: rgba(255, 255, 255, 0.06);
  }

  /* === Actions === */
  .nav__actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .nav__lang-dropdown {
    position: relative;
  }

  .nav__lang-trigger {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 1.25rem;
    color: var(--wc-charcoal);
    transition: color 0.4s ease;
    cursor: pointer;
  }

  .nav__lang-caret {
    font-size: 0.75rem;
    transition: transform 0.2s ease;
  }

  .nav__lang-trigger[aria-expanded="true"] .nav__lang-caret {
    transform: rotate(180deg);
  }

  .nav__lang-trigger:hover {
    color: var(--cpx-secondary);
  }

  .nav--dark .nav__lang-trigger {
    color: rgba(250, 248, 245, 0.8);
  }

  .nav--dark .nav__lang-trigger:hover {
    color: var(--wc-warm-white);
  }

  .nav__lang-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 140px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(195, 214, 221, 0.2);
    border-radius: 8px;
    padding: 6px 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .nav__lang-menu.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav--dark .nav__lang-menu {
    background: rgba(29, 29, 31, 0.95);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .nav__lang-option {
    display: block;
    padding: 8px 16px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--wc-charcoal);
    transition: background 0.15s ease;
  }

  .nav__lang-option:hover {
    background: rgba(195, 214, 221, 0.15);
  }

  .nav__lang-option.is-active {
    font-weight: 500;
    color: var(--cpx-secondary);
  }

  .nav--dark .nav__lang-option {
    color: rgba(250, 248, 245, 0.8);
  }

  .nav--dark .nav__lang-option:hover {
    background: rgba(255, 255, 255, 0.06);
  }

  .nav--dark .nav__lang-option.is-active {
    color: var(--cpx-accent);
  }

  .nav__cta {
    padding: 10px 28px;
    font-size: 0.6875rem;
  }

  /* === Hamburger === */
  .nav__hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
  }

  .nav__hamburger span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--wc-charcoal);
    transition: all 0.3s ease;
  }

  .nav--dark .nav__hamburger span {
    background: var(--wc-warm-white);
  }

  .nav__hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: rotate(45deg) translate(4px, 4px);
  }

  .nav__hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .nav__hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* === Mobile overlay === */
  .nav__mobile {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 99;
    background: var(--wc-warm-white);
    display: flex;
    flex-direction: column;
    padding: 80px 32px 40px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s var(--ease-soft);
  }

  .nav__mobile.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .nav__mobile-close {
    position: absolute;
    top: 20px;
    left: 24px;
    color: var(--wc-charcoal);
    padding: 8px;
  }

  .nav__mobile-links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 28px;
    flex: 1;
  }

  .nav__mobile-links > a,
  .nav__mobile-heading {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.25rem;
    color: var(--wc-charcoal);
  }

  .nav__mobile-cta {
    align-self: center;
    font-size: 0.6875rem !important;
    padding: 12px 36px !important;
    color: #ffffff !important;
    letter-spacing: 0.08em;
    min-height: 0 !important;
    margin-top: 48px;
  }

  .nav__mobile-socials {
    display: flex;
    gap: 24px;
    margin-top: 24px;
    margin-bottom: 16px;
    align-self: center;
  }

  .nav__mobile-socials a {
    font-size: 1.75rem;
    color: var(--wc-charcoal);
    transition: color 0.2s ease;
  }

  .nav__mobile-socials a:hover {
    color: var(--cpx-secondary);
  }

  .nav__mobile-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  .nav__mobile-sub {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .nav__mobile-sub a {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.9375rem;
    color: var(--wc-charcoal);
    opacity: 0.5;
  }

  /* === Mobile layout === */
  .nav__logo-subtitle {
    display: none;
  }

  @media (max-width: 767px) {
    .nav__inner {
      display: grid;
      grid-template-columns: 40px 1fr 40px;
      grid-template-rows: auto auto;
      align-items: center;
      justify-items: center;
      height: auto;
      padding-top: 12px;
      padding-bottom: 12px;
      gap: 0;
    }

    .nav__hamburger {
      grid-column: 1;
      grid-row: 1 / 3;
      justify-self: start;
    }

    .nav__logo {
      grid-column: 2;
      grid-row: 1;
      justify-self: center;
      gap: 6px;
    }

    .nav__logo-img {
      height: 25px;
    }

    .nav__logo-subtitle {
      display: block;
      grid-column: 2;
      grid-row: 2;
      justify-self: center;
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 0.8125rem;
      letter-spacing: 0.02em;
      color: var(--wc-charcoal);
      opacity: 0.5;
      margin-top: -6px;
      transition: color 0.4s ease;
    }

    .nav--dark .nav__logo-subtitle {
      color: var(--wc-warm-white);
    }

    .nav__actions {
      grid-column: 3;
      grid-row: 1 / 3;
      justify-self: end;
    }

    .nav__links {
      display: none !important;
    }
  }
</style>

<script>
  // === Mobile toggle ===
  const toggle = document.getElementById('nav-toggle');
  const mobile = document.getElementById('nav-mobile');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    mobile?.classList.toggle('is-open');
    mobile?.setAttribute('aria-hidden', String(expanded));
    document.body.style.overflow = expanded ? '' : 'hidden';
  });

  const closeBtn = document.getElementById('nav-close');
  const closeMobile = () => {
    toggle?.setAttribute('aria-expanded', 'false');
    mobile?.classList.remove('is-open');
    mobile?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };

  closeBtn?.addEventListener('click', closeMobile);

  mobile?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMobile);
  });

  // === Language dropdown ===
  const langDropdown = document.getElementById('lang-dropdown');
  const langTrigger = langDropdown?.querySelector('.nav__lang-trigger');
  const langMenu = langDropdown?.querySelector('.nav__lang-menu');

  langTrigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const expanded = langTrigger.getAttribute('aria-expanded') === 'true';
    langTrigger.setAttribute('aria-expanded', String(!expanded));
    langMenu?.classList.toggle('is-open');
    langMenu?.setAttribute('aria-hidden', String(expanded));
  });

  document.addEventListener('click', () => {
    langTrigger?.setAttribute('aria-expanded', 'false');
    langMenu?.classList.remove('is-open');
    langMenu?.setAttribute('aria-hidden', 'true');
  });

  // === Adaptive header: dark ↔ light based on section underneath ===
  const nav = document.getElementById('nav');
  if (nav) {
    const darkSections = document.querySelectorAll('.section--dark');

    const checkNavTheme = () => {
      const navRect = nav.getBoundingClientRect();
      const navMidY = navRect.top + navRect.height / 2;
      let overDark = false;

      darkSections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        if (navMidY >= rect.top && navMidY <= rect.bottom) {
          overDark = true;
        }
      });

      // Also check the footer
      const footer = document.querySelector('.footer');
      if (footer) {
        const footerRect = footer.getBoundingClientRect();
        if (navMidY >= footerRect.top && navMidY <= footerRect.bottom) {
          overDark = true;
        }
      }

      if (overDark) {
        nav.classList.add('nav--dark');
      } else {
        nav.classList.remove('nav--dark');
      }
    };

    // Run on scroll with requestAnimationFrame for performance
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          checkNavTheme();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    // Initial check
    checkNavTheme();
  }
</script>
