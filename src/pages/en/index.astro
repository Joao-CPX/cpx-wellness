---
import Base from '../../layouts/Base.astro';
import { t, localeRoutes } from '../../i18n/utils';

const locale = 'en';
const i = t(locale);
const routes = localeRoutes[locale];
---

<Base title="Frequency-Based Wellness in Lisbon" locale={locale} description="CellPowerX Wellness Center - Lisbon's pioneering frequency-based wellness center. 20+ years of experience, 70,000+ client journeys. Electrotherapy, NanoPulse, Infrared & SLM Wave.">

  <!-- Hero -->
  <section class="hero">
    <img src="/images/hero.webp" alt="Nuno Nina at CellPowerX Wellness Center" class="hero__bg" loading="eager" />
    <div class="hero__overlay"></div>
    <div class="container hero__inner">
      <div class="hero__content">
        <span class="label reveal">{i.hero.label}</span>
        <h1 class="reveal">{i.hero.heading}</h1>
        <p class="hero__body reveal">{i.hero.body}</p>
        <p class="hero__former reveal">{i.hero.formerName}</p>
        <div class="hero__actions reveal">
          <a href={routes.contact} class="btn hero__btn-primary">
            {i.hero.ctaPrimary}
            <i class="ph-light ph-arrow-right"></i>
          </a>
          <a href={routes.treatments} class="btn btn--secondary hero__btn-secondary">
            {i.hero.ctaSecondary}
            <i class="ph-light ph-arrow-right"></i>
          </a>
        </div>
      </div>
    </div>
    <div class="hero__stats">
      <div class="hero__stat">
        <i class="ph-fill ph-star hero__stat-star"></i>
        <div class="hero__stat-text">
          <strong>4.9/5</strong>
          <span>Google Reviews</span>
        </div>
      </div>
      <div class="hero__stat">
        <i class="ph-light ph-users"></i>
        <div class="hero__stat-text">
          <strong>70,000+</strong>
          <span>Client Journeys</span>
        </div>
      </div>
      <div class="hero__stat">
        <i class="ph-light ph-calendar-blank"></i>
        <div class="hero__stat-text">
          <strong>Since 2009</strong>
          <span>Pioneers in Electrotherapy</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Welcome -->
  <section class="section section--accent">
    <div class="container">
      <div class="welcome-block reveal">
        <h2 class="welcome-block__heading">Welcome to CellPowerX Wellness Center</h2>
        <p class="welcome-block__lead">Experience the Impossible at Our Wellness Center.</p>
        <p>Nestled in the vibrant heart of Lisbon, between Saldanha and Marquês de Pombal, our Wellness Center offers a gateway to revolutionary well-being. With cutting-edge electrotherapy technology at your fingertips, embrace the myriad benefits that this modern approach to wellness provides.</p>
        <p>Our dedicated team, with over a decade of experience working alongside Nuno Nina, is expertly trained in his renowned methods and protocols. We are not just a Wellness Center; we are a wellness community, eager to support your wellness journey.</p>
        <p>Visit us today and discover a new standard in personalized care. We are excited to welcome you!</p>
      </div>
    </div>
  </section>

  <!-- Treatments Preview -->
  <section class="section">
    <div class="container">
      <h2 class="text-center reveal" style="margin-bottom: var(--block-spacing);">
        {i.treatmentsPreview.heading}
      </h2>
      <div class="grid-4 services-carousel" data-stagger>
        {[
          { key: 'slmwave', img: '/images/slmwave.webp', pos: 'center center' },
          { key: 'nanopulse', img: '/images/nanopulse.webp', pos: 'left center' },
          { key: 'infrared', img: '/images/infrared.webp', pos: 'center center' },
          { key: 'timewaver', img: '/images/timewaver.webp', pos: 'right center' },
        ].map(({ key, img, pos }) => (
          <a href={`${routes.treatments}#${key}`} class="service-card">
            <div class="service-card__img-wrap">
              <img src={img} alt={i.treatmentsPreview[key].name} class="service-card__img" style={`object-position: ${pos};`} loading="lazy" />
              <div class="service-card__overlay"></div>
              <div class="service-card__content">
                <p class="service-card__tagline">{i.treatmentsPreview[key].tagline}</p>
                <h4 class="service-card__title">{i.treatmentsPreview[key].name}</h4>
                <span class="service-card__btn">{i.treatmentsPreview.learnMore} <i class="ph-light ph-arrow-right"></i></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- Value Props -->
  <section class="section vp-section">
    <div class="container">
      <div class="vp-grid" data-stagger>
        <div class="vp">
          <i class="ph-light ph-dna vp__icon"></i>
          <h3 class="vp__title">{i.valueProps.card1Title}</h3>
          <p class="vp__text">{i.valueProps.card1Text}</p>
        </div>
        <div class="vp">
          <i class="ph-light ph-circuitry vp__icon"></i>
          <h3 class="vp__title">{i.valueProps.card2Title}</h3>
          <p class="vp__text">{i.valueProps.card2Text}</p>
        </div>
        <div class="vp">
          <i class="ph-light ph-users-three vp__icon"></i>
          <h3 class="vp__title">{i.valueProps.card3Title}</h3>
          <p class="vp__text">{i.valueProps.card3Text}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote -->
  <section class="section section--accent">
    <div class="container text-center">
      <blockquote class="quote reveal">
        <p class="quote__text">"{i.quote.text}"</p>
        <footer class="quote__attribution">
          <strong>{i.quote.author}</strong> - {i.quote.role}
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- First Appointment CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-block cta-block--centered reveal">
        <h2>{i.firstAppointment.heading}</h2>
        <p class="cta-block__body">{i.firstAppointment.body}</p>
        <a href={routes.contact} class="btn btn--cta" style="margin-top: 32px;">
          {i.firstAppointment.cta}
          <i class="ph-light ph-arrow-right"></i>
        </a>
        <div class="cta-block__location">
          <i class="ph-light ph-map-pin"></i>
          <span>{i.firstAppointment.location} · {i.firstAppointment.locationDetail}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CellPowerX Ecosystem -->
  <section class="cpx-banner reveal">
    <img src="https://www.cellpowerx.com/cdn/shop/files/Wellness_is_evolving_3200x1600_baec34e8-3d1e-4ed4-b8e1-636cd2ec8610.webp?v=1767977609&width=3000" alt="CellPowerX Ecosystem" class="cpx-banner__img" loading="lazy" />
    <div class="cpx-banner__overlay"></div>
    <div class="cpx-banner__content">
      <h2>{i.about.ecosystemHeading}</h2>
      <p>{i.about.ecosystemBody}</p>
      <a href="https://www.cellpowerx.com" target="_blank" rel="noopener" class="btn btn--cta">
        {i.about.ecosystemCta}
        <i class="ph-light ph-arrow-up-right"></i>
      </a>
    </div>
  </section>


</Base>

<style>
  /* Welcome block */
  .welcome-block {
    text-align: center;
  }

  .welcome-block__heading {
    margin-bottom: 28px;
    max-width: none;
  }

  .welcome-block__lead {
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--cpx-accent);
    max-width: none;
    margin-bottom: 20px;
  }

  .welcome-block p {
    max-width: 780px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 16px;
    line-height: 1.75;
  }

  .welcome-block p:last-child {
    margin-bottom: 0;
  }

  .hero__stats {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    padding: 16px var(--grid-padding);
    background: none;
  }

  .hero__stat {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    justify-content: center;
  }

  .hero__stat i {
    font-size: 1.25rem;
    color: rgba(250, 248, 245, 0.7);
  }

  .hero__stat-star {
    color: #FBBC04 !important;
  }

  .hero__stat-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .hero__stat-text strong {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 0.875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--wc-warm-white);
  }

  .hero__stat-text span {
    font-size: 0.6875rem;
    color: rgba(250, 248, 245, 0.5);
    max-width: none;
  }

  @media (max-width: 767px) {
    .hero__stats { display: none; }
  }

  .hero h1 {
    text-align: left;
    margin-left: 0;
    margin-right: 0;
  }

  /* Hero */
  .hero {
    position: relative;
    margin-top: 72px;
    padding: var(--section-spacing) 0;
    min-height: 500px;
    max-height: 640px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0, 0, 0, 0.65), rgba(0, 0, 0, 0));
  }

  @media (max-width: 767px) {
    .hero {
      margin-top: 53px;
    }

    .hero__overlay {
      background: rgba(0, 0, 0, 0.5);
    }
  }

  .hero__inner {
    position: relative;
    z-index: 1;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--element-spacing);
    max-width: 640px;
  }

  .hero .label {
    color: #ffffff;
  }

  .hero h1 {
    color: var(--wc-warm-white);
  }

  .hero__body {
    font-size: 1.0625rem;
    line-height: 1.5;
    max-width: 520px;
    color: rgba(250, 248, 245, 0.85);
  }

  .hero__former {
    font-size: 0.8125rem;
    font-style: italic;
    color: rgba(250, 248, 245, 0.5);
    margin-top: 8px;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 8px;
  }

  .hero__btn-primary {
    background: var(--cpx-secondary);
    color: #ffffff;
    border: none;
  }

  .hero__btn-primary:hover {
    background: #e03d12;
    box-shadow: 0 8px 24px rgba(251, 70, 22, 0.3);
  }

  .hero__btn-secondary {
    background: transparent;
    border-color: rgba(250, 248, 245, 0.3);
    color: var(--wc-warm-white);
  }

  .hero__btn-secondary:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(250, 248, 245, 0.6);
    color: #ffffff;
  }

  /* Services carousel - horizontal scroll on mobile */
  @media (max-width: 767px) {
    .services-carousel {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 16px;
      padding-bottom: 8px;
      margin-left: -20px;
      margin-right: -20px;
      padding-left: 20px;
      padding-right: 20px;
    }

    .services-carousel::-webkit-scrollbar {
      display: none;
    }

    .services-carousel .service-card {
      flex: 0 0 72%;
      scroll-snap-align: start;
    }
  }

  /* Service Cards (Apple style) */
  .service-card { display: flex; flex-direction: column; text-decoration: none; }

  .service-card__img-wrap {
    position: relative;
    border-radius: var(--radius-block);
    overflow: hidden;
    aspect-ratio: 3/4;
    background: var(--wc-mist);
  }

  .service-card__img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .service-card:hover .service-card__img { transform: scale(1.05); }

  .service-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    transition: background 0.4s ease;
  }

  .service-card:hover .service-card__overlay {
    background: rgba(0, 0, 0, 0.6);
  }

  .service-card__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 28px 24px;
    gap: 10px;
  }

  .service-card__tagline {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.5;
    max-width: none;
    margin: 0;
  }

  .service-card__title {
    font-family: var(--font-heading);
    font-weight: var(--fw-heading);
    font-size: clamp(1.125rem, 1.5vw, 1.375rem);
    text-transform: uppercase;
    letter-spacing: var(--tracking-heading);
    color: #ffffff;
    margin: 0;
    text-align: left;
  }

  .service-card__btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    align-self: flex-start;
    padding: 8px 18px;
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: var(--radius-button);
    transition: background 0.25s ease, border-color 0.25s ease;
  }

  .service-card:hover .service-card__btn {
    background: rgba(255, 255, 255, 0.15);
    border-color: #ffffff;
  }

  /* Quote */
  /* Value Props */
  .vp-section {
    background: var(--cpx-dark-bg);
  }

  .vp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .vp {
    padding: 0 48px 0 0;
    padding-top: 0;
  }

  .vp + .vp {
    padding-left: 48px;
    padding-right: 48px;
    border-left: 1px solid rgba(255, 255, 255, 0.15);
  }

  .vp:last-child {
    padding-right: 0;
  }

  .vp__icon {
    font-size: 2rem;
    color: rgba(255, 255, 255, 0.6);
    display: block;
    margin-bottom: 20px;
  }

  .vp__title {
    font-size: clamp(0.875rem, 1.1vw, 1rem);
    margin-bottom: 12px;
    text-align: left;
    margin-left: 0;
    margin-right: 0;
    color: #ffffff;
  }

  .vp__text {
    font-size: 0.9rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.7);
    max-width: none;
  }

  @media (max-width: 767px) {
    .vp-grid { grid-template-columns: 1fr; gap: 40px; }
    .vp { padding: 24px 0 0 0 !important; border-left: none !important; border-top: 1px solid rgba(255,255,255,0.15); }
    .vp:first-child { border-top: none; padding-top: 0 !important; }
  }

  .quote {
    max-width: 720px;
    margin: 0 auto;
  }

  .quote__text {
    font-family: var(--font-body);
    font-weight: var(--fw-body);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.6;
    font-style: italic;
    max-width: none;
    margin-bottom: 24px;
  }

  .quote__attribution {
    font-family: var(--font-heading);
    font-weight: var(--fw-heading);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
    color: var(--wc-charcoal);
  }

  /* CellPowerX Banner */
  .cpx-banner {
    position: relative;
    overflow: hidden;
    min-height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cpx-banner__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cpx-banner__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
  }

  .cpx-banner__content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 640px;
    padding: var(--section-spacing) 20px;
    color: var(--wc-warm-white);
  }

  .cpx-banner__content h2 {
    color: var(--wc-warm-white);
    margin-bottom: 16px;
  }

  .cpx-banner__content p {
    font-size: 1rem;
    line-height: 1.5;
    opacity: 0.85;
    max-width: none;
    margin-bottom: 32px;
  }

  /* CTA Block */
  .cta-block {
    max-width: 640px;
  }

  .cta-block--centered {
    text-align: center;
    margin: 0 auto;
  }

  .cta-block--centered p {
    margin-left: auto;
    margin-right: auto;
  }

  .cta-block--centered .cta-block__location {
    justify-content: center;
  }

  .cta-block__body {
    font-size: 1.0625rem;
    line-height: 1.5;
    margin-top: 16px;
    max-width: none;
  }

  .cta-block__location {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 24px;
    font-size: 0.875rem;
    color: var(--wc-sage);
  }

  .cta-block__location i {
    color: var(--cpx-accent);
  }

  /* Newsletter */
  .newsletter h2 {
    margin-bottom: 12px;
  }

  .newsletter p {
    margin-bottom: 32px;
  }

  .newsletter__form {
    display: flex;
    gap: 12px;
    max-width: 480px;
    margin: 0 auto;
  }

  .newsletter__form .input {
    flex: 1;
  }

  .newsletter__input {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
    color: var(--wc-warm-white);
  }

  .newsletter__input::placeholder {
    color: rgba(250, 248, 245, 0.35);
  }

  .newsletter__input:focus {
    border-color: var(--cpx-accent);
    background: rgba(255, 255, 255, 0.12);
  }

  @media (max-width: 480px) {
    .newsletter__form {
      flex-direction: column;
    }
  }
</style>
